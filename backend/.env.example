# Supabase project settings (Project Settings > API)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-secret-key
# No JWT secret needed - the backend verifies user tokens against Supabase's
# public JWKS endpoint (SUPABASE_URL + /auth/v1/.well-known/jwks.json).

# Google AI Studio free-tier key (aistudio.google.com/apikey) - used for both embeddings and chat
GOOGLE_API_KEY=your-google-api-key
GEMINI_CHAT_MODEL=gemini-2.5-flash-lite
GEMINI_EMBED_MODEL=gemini-embedding-001

# Storage bucket name (create this bucket in Supabase Storage, private)
DOCUMENTS_BUCKET=documents

# Comma-separated list of allowed origins for CORS (your Vercel URL + localhost for dev)
FRONTEND_ORIGINS=http://localhost:3000
